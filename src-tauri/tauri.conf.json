{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ckourse",
  "version": "1.10.24",
  "identifier": "com.ckourse.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Ckourse",
        "width": 1280,
        "height": 800,
        "maximized": true,
        "titleBarStyle": "Overlay",
        "acceptFirstMouse": true,
        "backgroundColor": "#0A0A0A"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**"
          ],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ffprobe",
      "binaries/ffmpeg"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": null
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/esdcti/ckourse-eduardo/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1MjgyNzM5Mjk4RDgzRTEKUldUaGc0MHBPU2NvbFRJU0I4RWlnWDBVcG94LzdkUWNKSzFZTlNoS1JrY21neEdydlNnK2tnMHAK"
    }
  }
}
